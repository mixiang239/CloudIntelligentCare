<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 紧急呼叫按钮 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_emergency_call_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeColor="@null"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_red"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="紧急呼叫"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="立即联系紧急联系人"
                    android:textColor="@color/white_90"
                    android:textSize="24sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_call"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:padding="24dp"
                    android:text="拨打求救电话"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_phone"
                    app:iconPadding="0dp"
                    android:backgroundTint="@color/white"
                    app:strokeColor="@null"
                    app:strokeWidth="0dp"
                    android:textColor="@color/red_600"
                    app:iconTint="@color/red_600"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 快捷操作 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_quick_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_emergency_call_button"
            app:layout_constraintStart_toStartOf="@id/card_emergency_call_button"
            app:layout_constraintEnd_toEndOf="@id/card_emergency_call_button"
            android:layout_marginTop="@dimen/cardMarginTop"
            >

            <!-- 警报测试卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_alert_test"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@null"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/card_safety_report"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/ic_warning"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="警报测试"
                        android:textColor="@color/gray_800"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:text="测试警报音"
                        android:textColor="@color/gray_600"
                        android:textSize="16sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 平安报告卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_safety_report"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@null"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toTopOf="@id/card_alert_test"
                app:layout_constraintStart_toEndOf="@id/card_alert_test"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/card_alert_test"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/common_ic_shield"
                        android:tint="@color/blue_500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="平安报告"
                        android:textColor="@color/gray_800"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:text="发送平安"
                        android:textColor="@color/gray_600"
                        android:textSize="16sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 位置信息 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_location_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@null"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/layout_quick_action"
            app:layout_constraintStart_toStartOf="@id/layout_quick_action"
            app:layout_constraintEnd_toEndOf="@id/layout_quick_action"
            android:layout_marginTop="@dimen/cardMarginTop"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:padding="20dp"
                >

                <!--定位图标-->
                <ImageView
                    android:id="@+id/ic_location"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_location"
                    android:tint="@color/blue_500"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/text_term_current_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前位置"
                    android:gravity="center"
                    android:textColor="@color/gray_800"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/ic_location"
                    app:layout_constraintBottom_toBottomOf="@id/ic_location"
                    app:layout_constraintStart_toEndOf="@id/ic_location"
                    android:layout_marginStart="8dp"
                    />

                <TextView
                    android:id="@+id/text_exact_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="北京市朝阳区望京街道"
                    android:textColor="@color/gray_700"
                    android:textSize="18sp"
                    app:layout_constraintTop_toBottomOf="@id/text_term_current_location"
                    app:layout_constraintStart_toStartOf="@id/text_term_current_location"
                    android:layout_marginTop="8dp"
                    />

                <TextView
                    android:id="@+id/text_location_sharing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="已启用实时位置共享"
                    android:textColor="@color/gray_500"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/text_exact_location"
                    app:layout_constraintStart_toStartOf="@id/text_exact_location"
                    />

                <!-- 查看位置按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_view_map"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_blue_500"
                    app:backgroundTint="@null"
                    android:text="查看地图"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/text_location_sharing"
                    app:layout_constraintStart_toStartOf="@id/text_location_sharing"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 呼叫历史 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_call_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/amber_200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_location_info"
            app:layout_constraintStart_toStartOf="@id/card_location_info"
            app:layout_constraintEnd_toEndOf="@id/card_location_info"
            android:layout_marginTop="@dimen/cardMarginTop"
            android:layout_marginHorizontal="2dp"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_gradient_yellow"
                android:padding="20dp"
                >

                <ImageView
                    android:id="@+id/ic_call_history"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_history"
                    android:tint="@color/amber_600"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/text_term_recent_call"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最近呼叫"
                    android:textColor="@color/gray_800"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/ic_call_history"
                    app:layout_constraintStart_toEndOf="@id/ic_call_history"
                    app:layout_constraintBottom_toBottomOf="@id/ic_call_history"
                    android:layout_marginStart="8dp"
                    />

                <TextView
                    android:id="@+id/text_last_call_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="上次呼叫: 女儿小芳"
                    android:textColor="@color/gray_700"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/ic_call_history"
                    app:layout_constraintStart_toStartOf="@id/ic_call_history"
                    android:layout_marginTop="8dp"
                    />

                <TextView
                    android:id="@+id/text_last_call_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="3天前"
                    android:textColor="@color/gray_500"
                    android:textSize="16sp"
                    app:layout_constraintTop_toTopOf="@id/text_last_call_info"
                    app:layout_constraintBottom_toBottomOf="@id/text_last_call_info"
                    app:layout_constraintEnd_toEndOf="parent"
                    />

                <TextView
                    android:id="@+id/text_term_monthly_calls"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="本月呼叫次数"
                    android:textColor="@color/gray_700"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/text_last_call_info"
                    app:layout_constraintStart_toStartOf="@id/text_last_call_info"
                    android:layout_marginTop="8dp"
                    />

                <TextView
                    android:id="@+id/text_monthly_calls_cnt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="1次"
                    android:textColor="@color/amber_600"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/text_term_monthly_calls"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/text_term_monthly_calls"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 紧急联系人 -->
        <TextView
            android:id="@+id/text_term_emergency_contacts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="紧急联系人"
            android:textColor="@color/gray_800"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@+id/card_call_history"
            app:layout_constraintStart_toStartOf="@+id/card_call_history"
            android:layout_marginTop="@dimen/cardMarginTop"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_emer_contacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/text_term_emergency_contacts"
            app:layout_constraintStart_toStartOf="@id/text_term_emergency_contacts"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            />

        <!-- 添加紧急联系人按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_add_contact_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_blue_500"
            app:backgroundTint="@null"
            android:text="+ 添加紧急联系人"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/recyclerview_emer_contacts"
            app:layout_constraintStart_toStartOf="@id/recyclerview_emer_contacts"
            app:layout_constraintEnd_toEndOf="@id/recyclerview_emer_contacts"
            android:layout_marginTop="@dimen/cardMarginTop"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>