<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@null"
    app:strokeWidth="0dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        >

        <ImageView
            android:id="@+id/ic_contacts"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_contacts"
            android:background="@drawable/bg_gradient_blue"
            app:layout_constraintTop_toTopOf="@id/text_contact_name"
            app:layout_constraintBottom_toBottomOf="@id/text_group"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="20dp"
            />

        <TextView
            android:id="@+id/text_contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="女儿 小芳"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="24sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ic_contacts"
            app:layout_constraintBottom_toTopOf="@id/text_contact_number"
            android:layout_marginStart="18dp"
            android:layout_marginTop="16dp"
            />

        <TextView
            android:id="@+id/text_contact_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="138 8888 6666"
            android:textColor="@color/gray_500"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/text_contact_name"
            app:layout_constraintStart_toStartOf="@id/text_contact_name"
            android:layout_marginTop="4dp"
            />

        <TextView
            android:id="@+id/text_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="家人"
            android:background="@drawable/bg_translucent_blue"
            android:textColor="@color/blue_500"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/text_contact_number"
            app:layout_constraintStart_toStartOf="@id/text_contact_number"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            />

        <ImageView
            android:id="@+id/ic_call"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_call"
            android:tint="@color/white"
            android:background="@drawable/bg_round_green"
            app:layout_constraintTop_toTopOf="@id/ic_contacts"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/ic_contacts"
            android:layout_marginEnd="20dp"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>



</com.google.android.material.card.MaterialCardView>