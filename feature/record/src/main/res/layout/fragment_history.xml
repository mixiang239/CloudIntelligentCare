<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_gray"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            >

            <TextView
                android:id="@+id/text_record_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="监护记录"
                android:textColor="@color/gray_800"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                />

            <TextView
                android:id="@+id/text_record_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="查看历史监测数据"
                android:textColor="@color/gray_600"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/text_record_title"
                app:layout_constraintStart_toStartOf="@id/text_record_title"
                />

            <ImageView
                android:id="@+id/ic_filter"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_filter"
                android:background="@drawable/bg_gradient_blue"
                app:layout_constraintTop_toTopOf="@id/text_record_title"
                app:layout_constraintBottom_toBottomOf="@id/text_record_description"
                app:layout_constraintEnd_toEndOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 日期筛选 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/card_filter"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/layout_header"
            android:layout_marginTop="@dimen/cardMarginTop"
            >

            <AutoCompleteTextView
                android:id="@+id/autoCompleteTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请选择时间范围"
                android:inputType="none"
                android:text="最近7天"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="8dp"
                android:padding="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!--正常记录-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_normal_records"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/green_200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@+id/card_filter"
            app:layout_constraintStart_toStartOf="@+id/card_filter"
            app:layout_constraintEnd_toStartOf="@id/card_abnormal_alert"
            android:layout_marginTop="@dimen/cardMarginTop"
            android:layout_marginStart="2dp"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F1FDF4"
                android:padding="16dp"
                >

                <TextView
                    android:id="@+id/text_term_normal_records"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="正常记录"
                    android:textColor="@color/gray_700"
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/text_normal_records_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="24"
                    android:textColor="@color/green_600"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/text_term_normal_records"
                    app:layout_constraintStart_toStartOf="@id/text_term_normal_records"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>



        </com.google.android.material.card.MaterialCardView>

        <!--异常提醒-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_abnormal_alert"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/amber_200"
            app:strokeWidth="1dp"
            app:layout_constraintStart_toEndOf="@id/card_normal_records"
            app:layout_constraintTop_toTopOf="@id/card_normal_records"
            app:layout_constraintBottom_toBottomOf="@id/card_normal_records"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="2dp"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFBEB"
                android:padding="16dp"
                >

                <TextView
                    android:id="@+id/text_term_abnormal_alert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="异常提醒"
                    android:textColor="@color/gray_700"
                    android:textSize="18sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:id="@+id/text_abnormal_alert_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="2"
                    android:textColor="@color/amber_600"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/text_term_abnormal_alert"
                    app:layout_constraintStart_toStartOf="@id/text_term_abnormal_alert"
                    />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 历史列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/card_normal_records"
            app:layout_constraintStart_toStartOf="@id/card_normal_records"
            app:layout_constraintEnd_toEndOf="@id/card_normal_records"
            android:layout_marginTop="@dimen/cardMarginTop"
            />

        <!-- Load More Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_load_more"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cardMarginTop"
            android:background="@drawable/bg_blue_100"
            app:backgroundTint="@null"
            android:text="加载更多记录"
            android:textAllCaps="false"
            android:textColor="@color/gray_700"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/recyclerView_history"
            app:layout_constraintStart_toStartOf="@id/recyclerView_history"
            app:layout_constraintEnd_toEndOf="@id/recyclerView_history"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>