<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 用户资料卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_user_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeColor="@null"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/setting_bg_gradient_blue"
                >

                <ImageView
                    android:id="@+id/ic_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/bg_white_20"
                    android:padding="16dp"
                    android:src="@drawable/ic_contacts"
                    app:tint="@color/white"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="16dp"
                    />

                <TextView
                    android:id="@+id/text_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="张大爷"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/ic_avatar"
                    app:layout_constraintStart_toEndOf="@id/ic_avatar"
                    android:layout_marginStart="12dp"
                    />

                <TextView
                    android:id="@+id/text_user_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="78岁 · 已监护365天"
                    android:textColor="@color/white_90"
                    android:textSize="18sp"
                    app:layout_constraintTop_toBottomOf="@id/text_user_name"
                    app:layout_constraintStart_toStartOf="@id/text_user_name"
                    />

                <!--健康天数-->
                <LinearLayout
                    android:id="@+id/layout_health_days"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:background="@drawable/setting_bg_gradient_white"
                    app:layout_constraintTop_toBottomOf="@id/ic_avatar"
                    app:layout_constraintStart_toStartOf="@id/ic_avatar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_contacts_number"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="14dp"
                    android:layout_marginEnd="6dp"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="24"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:text="健康天数"
                        android:textColor="@color/white_80"
                        android:textSize="14sp" />

                </LinearLayout>

                <!--联系人数量-->
                <LinearLayout
                    android:id="@+id/layout_contacts_number"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:background="@drawable/setting_bg_gradient_white"
                    app:layout_constraintTop_toTopOf="@id/layout_health_days"
                    app:layout_constraintBottom_toBottomOf="@id/layout_health_days"
                    app:layout_constraintStart_toEndOf="@id/layout_health_days"
                    app:layout_constraintEnd_toStartOf="@id/layout_safety_rate"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:text="联系人"
                        android:textColor="@color/white_80"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_safety_rate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:background="@drawable/setting_bg_gradient_white"
                    app:layout_constraintTop_toTopOf="@id/layout_contacts_number"
                    app:layout_constraintStart_toEndOf="@id/layout_contacts_number"
                    app:layout_constraintBottom_toBottomOf="@id/layout_contacts_number"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="16dp"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="98%"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:text="安全率"
                        android:textColor="@color/white_80"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView_setting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/card_user_profile"
            app:layout_constraintStart_toStartOf="@id/card_user_profile"
            app:layout_constraintEnd_toEndOf="@id/card_user_profile"
            android:layout_marginTop="@dimen/cardMarginTop"
            android:clipToPadding="false"
            android:paddingHorizontal="2dp"
            />

        <!-- 应用信息 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_app_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/gray_200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/recyclerView_setting"
            app:layout_constraintStart_toStartOf="@id/recyclerView_setting"
            app:layout_constraintEnd_toEndOf="@id/recyclerView_setting"
            android:layout_marginTop="@dimen/cardMarginTop"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F9FAFB"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="云智康护 v1.0.0"
                    android:textColor="@color/gray_600"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="智能防跌倒监护系统"
                    android:textColor="@color/gray_500"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/red_600"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_app_info"
            app:layout_constraintStart_toStartOf="@id/card_app_info"
            app:layout_constraintEnd_toEndOf="@id/card_app_info"
            android:layout_marginTop="@dimen/cardMarginTop"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp"
                android:background="#FDF2F2"
                >

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    >
                    <ImageView
                        android:id="@+id/ic_logout"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_logout"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/text_logout"
                        android:layout_marginEnd="2dp"
                        />

                    <TextView
                        android:id="@+id/text_logout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="退出登录"
                        android:textSize="20sp"
                        android:textColor="@color/red_600"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ic_logout"
                        android:layout_marginStart="2dp"
                        />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- 用户服务 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_customer_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/blue_200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_logout"
            app:layout_constraintStart_toStartOf="@id/card_logout"
            app:layout_constraintEnd_toEndOf="@id/card_logout"
            android:layout_marginTop="@dimen/cardMarginTop"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F0F6FE"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="客服热线"
                    android:textColor="@color/gray_600"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/customer_service_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="400-888-6666"
                    android:textColor="@color/blue_600"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="工作时间: 9:00-18:00"
                    android:textColor="@color/gray_500"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>