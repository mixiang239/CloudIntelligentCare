<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >


    <ImageView
        android:id="@+id/ic_icon"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/ic_contacts"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginVertical="14dp"
        />

    <TextView
        android:id="@+id/text_setting_option"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="个人信息"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="@id/ic_icon"
        app:layout_constraintBottom_toBottomOf="@id/ic_icon"
        app:layout_constraintStart_toEndOf="@id/ic_icon"
        android:layout_marginStart="10dp"
        />


    <TextView
        android:id="@+id/text_simple_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="张大爷"
        android:textColor="@color/gray_500"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/text_setting_option"
        app:layout_constraintBottom_toBottomOf="@id/text_setting_option"
        app:layout_constraintEnd_toStartOf="@+id/ic_more"
        android:layout_marginEnd="8dp"
        />

    <ImageView
        android:id="@+id/ic_more"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_more"
        app:layout_constraintTop_toTopOf="@id/text_simple_description"
        app:layout_constraintBottom_toBottomOf="@id/text_simple_description"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        />

    <View
        android:id="@+id/view_divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/gray_200"
        app:layout_constraintBottom_toBottomOf="parent"
        />
</androidx.constraintlayout.widget.ConstraintLayout>